# AutoResearch — TinyStories / T4
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# Anthropic API key (required)
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# GCP project ID (required)
# Found in GCP Console → project selector
GCP_PROJECT=your-gcp-project-id

# Firestore database name (required only if not using the default database)
# Leave blank or omit if your database is named "(default)"
FIRESTORE_DATABASE=your-firestore-database-name

# Overnight run budget in hours (optional, default: 8)
# RUN_HOURS=8
